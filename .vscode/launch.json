{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ori: agent (CLI)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/ori",
      "args": ["agent"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "ori: gateway",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/ori",
      "args": ["gateway"],
      "cwd": "${workspaceFolder}",
    },
    {
      "name": "ori: version",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/ori",
      "args": ["version"],
      "cwd": "${workspaceFolder}",
    },
    {
      "name": "ori: current file test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "cwd": "${workspaceFolder}",
    }
  ]
}
