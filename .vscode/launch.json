{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "nanobot: agent (CLI)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/nanobot",
      "args": ["agent", "-m", "介绍下当前目录的文件", "-s", "cli:direct"],
      "cwd": "${workspaceFolder}",
    },
    {
      "name": "nanobot: gateway",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/nanobot",
      "args": ["gateway"],
      "cwd": "${workspaceFolder}",
    },
    {
      "name": "nanobot: version",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/nanobot",
      "args": ["version"],
      "cwd": "${workspaceFolder}",
    },
    {
      "name": "nanobot: current file test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "cwd": "${workspaceFolder}",
    }
  ]
}
